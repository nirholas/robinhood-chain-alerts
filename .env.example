# hood-alerts service configuration.
# Copy to `.env` and fill in what you need. `.gitignore` covers `.env*` except
# this file. Every variable below is optional unless the comment says otherwise:
# the service starts with no credentials at all in DRY_RUN mode.

# ---- chain ----------------------------------------------------------------

# Which network to watch. Only `mainnet` (chain 4663) has the NOXA and Odyssey
# launchpads deployed; starting on `testnet` fails fast rather than reporting
# an empty chain as "no launches".
NETWORK=mainnet

# Custom RPC. Defaults to the public endpoint from viem's `robinhood` chain
# definition (https://rpc.mainnet.chain.robinhood.com). The public endpoint
# rate limits bursts, so a dedicated endpoint is worth it above a few hundred
# tracked pools.
# ROBINHOOD_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY

# Blocks to wait before treating a block as final. Robinhood Chain produces a
# block roughly every 100-130ms, so 2 confirmations costs about a quarter of a
# second of alert latency.
CONFIRMATIONS=2

# Max blocks read per source per poll. Larger drains a backlog faster, smaller
# is gentler on a rate-limited endpoint.
CHUNK_SIZE=2000

# Where a source starts when it has no persisted cursor: this many blocks
# behind the head. A fresh deployment should not replay months of history into
# a subscriber's chat.
INITIAL_LOOKBACK_BLOCKS=5000

# How often to poll for new blocks, and how often to drain the delivery outbox.
POLL_INTERVAL_MS=3000
FLUSH_INTERVAL_MS=1000

# ---- what counts as a whale ----------------------------------------------

# Service-wide floor for whale trades, in USD. Swaps below this never become
# events at all. Per-subscription `minUsd` rules are applied on top and can
# only be stricter.
WHALE_MIN_USD=1000

# How many memecoin pools the whale watcher queries per poll, newest first.
# Pools on a subscriber's watchlist are always included on top of this cap.
# Chain-wide swap queries are not possible on this RPC (a topic-only Uniswap v3
# `Swap` query overflows its 10,000-log result cap in under 2,000 blocks), so
# this bounds a real cost.
WHALE_POOL_LIMIT=400

# ---- service --------------------------------------------------------------

# SQLite file holding subscriptions, rules, the delivery outbox, dedupe keys
# and the block cursors. Put it on a persistent volume: deleting it loses
# subscriptions and replays the initial lookback window.
DB_PATH=./data/hood-alerts.sqlite

# HTTP port for /health, /ready, /metrics and the Discord interactions
# endpoint.
PORT=8080

# debug | info | warn | error. Logs are one JSON object per line.
LOG_LEVEL=info

# Render and queue alerts but log them instead of sending. Point a fresh
# deployment at mainnet with DRY_RUN=1 to watch exactly what would go out
# before handing it bot tokens.
DRY_RUN=0

# Delivery retry budget and backoff. A retryable failure (5xx, rate limit,
# network) is retried with exponential backoff; a permanent one (blocked bot,
# deleted webhook) is dead-lettered immediately.
MAX_DELIVERY_ATTEMPTS=6
RETRY_BACKOFF_MS=30000
FLUSH_BATCH_SIZE=50

# How long delivered outbox rows are kept before pruning.
OUTBOX_RETENTION_HOURS=72

# ---- Telegram -------------------------------------------------------------

# Bot token from @BotFather, in `<bot id>:<secret>` form. Set it and the
# Telegram bot starts long polling; leave it unset and Telegram is disabled.
# TELEGRAM_BOT_TOKEN=123456789:AA...

# ---- Discord --------------------------------------------------------------

# Discord webhook delivery needs no credential at all: a subscriber pastes a
# channel webhook URL into /subscribe and alerts arrive.
#
# The three variables below enable slash commands and bot-account delivery.
# All are on your application page at
# https://discord.com/developers/applications.
# DISCORD_APPLICATION_ID=000000000000000000
# DISCORD_BOT_TOKEN=...
# DISCORD_PUBLIC_KEY=...

# Path the service serves the Discord interactions endpoint on. Set your
# application's Interactions Endpoint URL to `https://<your host><this path>`.
DISCORD_INTERACTIONS_PATH=/discord/interactions

# ---- tiering and entitlements --------------------------------------------

# How premium is decided:
#   static - premium comes from PREMIUM_SUBSCRIBERS / ALL_PREMIUM (the default)
#   usdg   - premium is bought on chain with USDG (needs USDG_RECEIVER)
#   both   - configuration grants comps, the chain sells subscriptions
ENTITLEMENTS=static

# Comma-separated subscriber ids granted premium by configuration. The id is
# `telegram:<user id>` or `discord:<guild id>` (a Discord server pays once for
# all its channels). /tier prints the id the caller is billed as.
# PREMIUM_SUBSCRIBERS=telegram:12345678,discord:987654321098765432

# Treat everyone as premium. For a private, self-hosted deployment.
ALL_PREMIUM=0

# The address subscribers pay in USDG. Required when ENTITLEMENTS is `usdg` or
# `both`. The service reads USDG Transfer logs from a subscriber's linked,
# signature-verified wallet to this address and accrues subscription time from
# them: no facilitator, no card processor, no third-party service.
# USDG_RECEIVER=0x0000000000000000000000000000000000000000

# Price of one subscription period, in whole USDG (6 decimals on chain), and
# the period length. A payment of 75 USDG at a price of 25 buys three periods.
PREMIUM_PRICE_USDG=25
PREMIUM_PERIOD_DAYS=30

# First block scanned for payments. Set it to the block you deployed the
# receiver at, so a lapsed-subscription check is one selective log query.
PAYMENTS_FROM_BLOCK=0

# Shown by /upgrade. Free-form: tell subscribers exactly how to pay you.
# UPGRADE_INSTRUCTIONS=Send 25 USDG to 0x... on Robinhood Chain, then run /link.
